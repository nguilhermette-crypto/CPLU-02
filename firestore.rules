rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: abastecimentos
    // Document ID: recordId
    // Fields:
    //   - id: string (required)
    //   - plate: string (required)
    //   - driverName: string (required)
    //   - time: string (required)
    //   - truckKm: number (required)
    //   - horimeter: number (required)
    //   - liters: number (required)
    //   - pumpOdometer: number (required)
    //   - timestamp: string (required)
    //   - userId: string (required)
    //   - shiftId: string (required)
    //
    // Collection: turnos
    // Document ID: shiftId
    // Fields:
    //   - id: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - shiftType: string (required, enum: ["Manhã", "Tarde"])
    //   - initialPumpOdometer: number (required)
    //   - initialLiters: number (required)
    //   - remainingLiters: number (required)
    //   - status: string (required, enum: ["Aberto", "Fechado"])
    //   - timestamp: string (required)
    //   - userId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidFuelRecord(data) {
      return data.keys().hasAll(['id', 'plate', 'driverName', 'time', 'truckKm', 'horimeter', 'liters', 'pumpOdometer', 'timestamp', 'userId', 'shiftId']) &&
             data.id is string &&
             data.plate is string && data.plate.size() > 0 &&
             data.driverName is string && data.driverName.size() > 0 &&
             data.time is string &&
             data.truckKm is number &&
             data.horimeter is number &&
             data.liters is number && data.liters > 0 &&
             data.pumpOdometer is number &&
             data.timestamp is string &&
             data.userId == request.auth.uid &&
             data.shiftId is string;
    }

    function isValidShift(data) {
      return data.keys().hasAll(['id', 'date', 'time', 'shiftType', 'initialPumpOdometer', 'initialLiters', 'remainingLiters', 'status', 'timestamp', 'userId']) &&
             data.id is string &&
             data.date is string &&
             data.time is string &&
             data.shiftType in ['Manhã', 'Tarde'] &&
             data.initialPumpOdometer is number &&
             data.initialLiters is number &&
             data.remainingLiters is number &&
             data.status in ['Aberto', 'Fechado'] &&
             data.timestamp is string &&
             data.userId == request.auth.uid;
    }

    match /users/{userId}/abastecimentos/{recordId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidFuelRecord(request.resource.data);
    }

    match /users/{userId}/turnos/{shiftId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidShift(request.resource.data);
    }
  }
}
